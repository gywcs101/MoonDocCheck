name = "shop1111/moondoccheck"

version = "0.1.0"

readme = "README.md"

repository = "https://github.com/shop1111/moondoccheck.git"

license = "MIT"

keywords = [
  "moonbit",
  "documentation",
  "quality",
  "checker",
  "ci",
]

description = "A MoonBit documentation quality checker for open-source packages and contest submissions."

options(
  "preferred-target": "native",
)


import {
  "moonbitlang/async@0.19.4",
  "moonbitlang/x@0.4.45",
}
